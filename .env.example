# Servidor
PORT=5000

# Banco de dados PostgreSQL (opcional — sem banco, usa arquivo JSON)
DATABASE_URL=postgresql://user:password@localhost:5432/controle_ted

# JWT
JWT_SECRET=troque-me-em-producao
JWT_EXPIRES_IN=24h

# Armazenamento de dados em arquivo (fallback sem banco)
# TED_DATA_FILE=/caminho/absoluto/para/ted-sistema.json
# TED_DATA_DIR=/caminho/para/pasta/dados

# Frontend (Vite)
VITE_API_PORT=5000

# Logs
LOG_LEVEL=info
