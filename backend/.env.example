# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ted_controle

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=sua_chave_secreta_muito_segura_aqui
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# Persistência local em arquivo
# Se não definir, o sistema usará automaticamente a pasta `dados/` na raiz do projeto.
# TED_DATA_DIR=C:\ControleTED\dados
# TED_DATA_FILE=C:\ControleTED\dados\ted-sistema.json
