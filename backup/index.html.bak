<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Controle TED - Sistema de Execução Descentralizada</title>
    <!-- Favicon: simple SVG stored in project root -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="shortcut icon" href="/favicon.svg">
    <link rel="apple-touch-icon" href="/favicon.svg">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* JS functions moved to script block to avoid invalid CSS parsing */

        /* popularFiltrosTEDs moved to script block (to avoid JS inside <style>) */

        :root {
            /* Cores Primárias */
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --primary-light: #60a5fa;
            --primary-50: #eff6ff;
            --primary-100: #dbeafe;
            --primary-gradient: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
            --primary-gradient-hover: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
            
            /* Cores Secundárias */
            --secondary: #1f2937;
            --secondary-light: #374151;
            
            /* Cores de Estado */
            --success: #10b981;
            --success-light: #d1fae5;
            --success-dark: #059669;
            --danger: #ef4444;
            --danger-light: #fee2e2;
            --danger-dark: #dc2626;
            --warning: #f59e0b;
            --warning-light: #fef3c7;
            --warning-dark: #d97706;
            --info: #06b6d4;
            --info-light: #cffafe;
            
            /* Backgrounds */
            --bg-primary: #ffffff;
            --bg-secondary: #f8fafc;
            --bg-alt: #f1f5f9;
            --bg-hover: #f8fafc;
            
            /* Bordas */
            --border: #e2e8f0;
            --border-light: #f1f5f9;
            --border-dark: #cbd5e1;
            
            /* Texto */
            --text: #1e293b;
            --text-secondary: #475569;
            --text-light: #64748b;
            --text-muted: #94a3b8;
            
            /* Header */
            --header-blue: #1e40af;
            --header-gradient: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
            
            /* Sombras */
            --shadow-xs: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-sm: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
            --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-md: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
            --shadow-xl: 0 25px 50px -12px rgb(0 0 0 / 0.25);
            --shadow-inner: inset 0 2px 4px 0 rgb(0 0 0 / 0.05);
            --shadow-primary: 0 4px 14px 0 rgb(59 130 246 / 0.3);
            
            /* Border Radius */
            --radius-sm: 0.375rem;
            --radius: 0.5rem;
            --radius-md: 0.625rem;
            --radius-lg: 0.75rem;
            --radius-xl: 1rem;
            --radius-2xl: 1.5rem;
            --radius-full: 9999px;
            
            /* Espaçamento (escala 4px) */
            --space-1: 0.25rem;   /* 4px */
            --space-2: 0.5rem;    /* 8px */
            --space-3: 0.75rem;   /* 12px */
            --space-4: 1rem;      /* 16px */
            --space-5: 1.25rem;   /* 20px */
            --space-6: 1.5rem;    /* 24px */
            --space-8: 2rem;      /* 32px */
            --space-10: 2.5rem;   /* 40px */
            --space-12: 3rem;     /* 48px */
            --space-16: 4rem;     /* 64px */
            
            /* Transições */
            --transition-fast: all 0.15s ease;
            --transition: all 0.2s ease;
            --transition-slow: all 0.3s ease;
            
            /* Light mode (padrão) */
            --light: #f3f4f6;
        }

        /* Dark Mode */
        [data-theme="dark"] {
            --primary: #60a5fa;
            --primary-dark: #3b82f6;
            --primary-light: #93c5fd;
            --primary-50: #1e3a5f;
            --primary-100: #1e40af;
            --primary-gradient: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
            
            --secondary: #f1f5f9;
            --secondary-light: #e2e8f0;
            
            --success-light: #064e3b;
            --danger-light: #7f1d1d;
            --warning-light: #78350f;
            --info-light: #164e63;
            
            --bg-primary: #0f172a;
            --bg-secondary: #1e293b;
            --bg-alt: #334155;
            --bg-hover: #334155;
            
            --border: #334155;
            --border-light: #475569;
            --border-dark: #64748b;
            
            --text: #f1f5f9;
            --text-secondary: #cbd5e1;
            --text-light: #94a3b8;
            --text-muted: #64748b;

